{
  "name": "@nanostores/preact",
  "version": "1.1.0",
  "description": "Preact integration for Nano Stores, a tiny state manager with many atomic tree-shakable stores",
  "keywords": [
    "preact",
    "state",
    "state manager",
    "store"
  ],
  "license": "MIT",
  "author": "Andrey Sitnik <andrey@sitnik.ru>",
  "repository": "nanostores/preact",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ai"
    }
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test:lint": "oxlint .",
    "test:coverage": "pnpm bnt --coverage",
    "test:types": "check-dts",
    "test:size": "size-limit",
    "test": "pnpm run /^test:/"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@logux/oxc-configs": "^0.2.2",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "actions-up": "^1.12.0",
    "better-node-test": "^0.8.4",
    "check-dts": "^1.0.0",
    "clean-publish": "^6.0.5",
    "happy-dom": "^20.8.9",
    "nanodelay": "^2.0.2",
    "nanostores": "^1.2.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.18.1",
    "preact": "^10.29.0",
    "preact-render-to-string": "^6.6.7",
    "size-limit": "^12.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "nanostores": "^1.2.0",
    "preact": ">=10.0.0"
  },
  "size-limit": [
    {
      "import": {
        "index.js": "{ useStore }",
        "nanostores": "{ map, computed }"
      },
      "limit": "965 B"
    }
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  }
}
